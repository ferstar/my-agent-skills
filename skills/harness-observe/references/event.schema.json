{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/harness-observe/event.schema.json",
  "title": "Harness observation event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "timestamp",
    "run_id",
    "event_type",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "event_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "run_id": { "$ref": "#/$defs/label" },
    "event_type": {
      "enum": [
        "run_started",
        "turn_started",
        "turn_stopped",
        "phase_changed",
        "guard_decision",
        "verification",
        "run_finished",
        "feedback"
      ]
    },
    "status": { "enum": ["ok", "failed", "blocked", "skipped"] },
    "phase": {
      "enum": ["DISCOVER", "DECIDE", "IMPLEMENT", "VERIFY", "SHIP", "DONE"]
    },
    "outcome": {
      "enum": ["success", "partial", "failed", "blocked", "cancelled"]
    },
    "terminal_state_met": { "type": "boolean" },
    "task_kind": { "$ref": "#/$defs/label" },
    "scope_id": { "$ref": "#/$defs/label" },
    "runtime": { "$ref": "#/$defs/label" },
    "model": { "$ref": "#/$defs/label" },
    "permission_mode": { "$ref": "#/$defs/label" },
    "source": { "$ref": "#/$defs/label" },
    "skills": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/label" }
    },
    "authority": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "read-only",
          "edit",
          "push",
          "merge",
          "deploy",
          "workflow-state",
          "publish",
          "cleanup"
        ]
      }
    },
    "action": { "$ref": "#/$defs/label" },
    "decision": { "enum": ["allow", "deny", "not-required"] },
    "error_code": { "$ref": "#/$defs/label" },
    "feedback": { "enum": ["accepted", "reworked", "rejected"] },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "duration_ms": { "type": "integer", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "tool_calls": { "type": "integer", "minimum": 0 },
        "retries": { "type": "integer", "minimum": 0 },
        "evidence_count": { "type": "integer", "minimum": 0 },
        "changed_files_count": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "label": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
    }
  }
}
